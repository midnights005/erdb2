{
  "name": "erdb",
  "description": "ERDB generates poster, backdrop, and logo images with dynamic ratings on the fly.",
  "version": "2.13.2",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IbbyLabs/erdb.git"
  },
  "homepage": "https://github.com/IbbyLabs/erdb#readme",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "test": "node --experimental-strip-types --test tests/**/*.test.mjs",
    "lint": "eslint .",
    "clean": "next clean",
    "imdb:import": "node scripts/imdb-import.js",
    "fonts:install": "bash scripts/install-fonts-linux.sh",
    "fonts:install:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-fonts-windows.ps1",
    "postinstall": "node scripts/postinstall.js",
    "docker:up": "docker compose up --build",
    "docker:up:scale4": "docker compose up -d --build --scale app=4",
    "docker:down": "docker compose down",
    "commits:generate": "node scripts/generate-commits-json.mjs",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "better-sqlite3",
      "protobufjs",
      "re2",
      "sharp",
      "unrs-resolver"
    ]
  }
}
